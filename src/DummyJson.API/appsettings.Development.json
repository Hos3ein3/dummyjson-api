{
  "DatabaseProvider": "PostgreSQL",

  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=DummyJsonDb_Dev;Username=postgres;Password=postgres",
    "SqlServer": "Server=localhost;Database=DummyJsonDb_Dev;Trusted_Connection=True;TrustServerCertificate=True",
    "MongoDB": "mongodb://localhost:27017/DummyJsonDb_Dev",
    "Redis": "localhost:6379"
  },

  "JwtSettings": {
    "Secret": "dev-secret-key-change-in-production-must-be-32chars",
    "Issuer": "DummyJsonApi",
    "Audience": "DummyJsonClient",
    "ExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 30
  },

  "SeedDatabase": true,

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}
