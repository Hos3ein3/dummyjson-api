DatabaseProvider=PostgreSQL

ConnectionStrings__PostgreSQL=Host=PostgreSQL;Port=5432;Database=DummyJson.dev;Username=homelabadmin;Password=123456789012
ConnectionStrings__MongoDB=mongo://homelabadmin:123456789012@mongo:27017/DummyJsonDb?authSource=admin
ConnectionStrings__Redis=redis:6379


JwtSettings__Secret=CHANGE_ME_TO_A_VERY_LONG_SECURE_SECRET_KEY_AT_LEAST_32_CHARS
JwtSettings__Issuer=DummyJsonApi
JwtSettings__Audience=DummyJsonClient
JwtSettings__ExpirationMinutes=60
JwtSettings__RefreshTokenExpirationDays=7

SeedDatabase=false
SeedDataPath=SeedData
SeedImages=false

FeatureManagement__UseMongoDbForProducts=true
FeatureManagement__EnableV2Endpoints=true
FeatureManagement__EnableSwaggerInProduction=false
FeatureManagement__EnableRateLimiting=false
FeatureManagement__EnableEmailVerification=false
FeatureManagement__EnableHealthChecksUIAutoRequest=false
Serilog__WriteTo__0__Args__serverUrl=http://localhost:5341
Serilog__Properties__Environment=Production
Serilog__Properties__Application=DummyJsonApi

Cors__AllowedOrigins__0=http://localhost:4200
Cors__AllowedOrigins__1=https://localhost:4200
